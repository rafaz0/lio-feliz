# Lio Feliz — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores.

# === Nitro (obrigatório no Vercel) ===
# Define o preset de build do Nitro. No Vercel, deve ser "vercel".
# Local: não precisa definir (usa cloudflare-module como default).
NITRO_PRESET=vercel

# === Supabase (obrigatório) ===
# SUPABASE_URL em produção: https://<project-ref>.supabase.co (URL direta)
# SUPABASE_URL em dev/Lovable: https://c--<uuid>-prod.lovable.cloud (proxy Lovable)
SUPABASE_PROJECT_ID=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# === BRAPI (obrigatório para cotações B3) ===
BRAPI_TOKEN=

# === Stripe (opcional — apenas se usar pagamentos reais) ===
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# === Modo de Desenvolvimento ===
# true = usa store em memória (sem Supabase). false = usa Supabase real.
DEV_MODE=true

# === Sentry (opcional, recomendado para produção) ===
SENTRY_DSN=
