# Lio Feliz — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores.

# === Supabase (obrigatório) ===
SUPABASE_PROJECT_ID=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# === BRAPI (obrigatório para cotações B3) ===
BRAPI_TOKEN=

# === Stripe (obrigatório para pagamentos) ===
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# === Modo de Desenvolvimento ===
# true = usa store em memória (sem Supabase). false = usa Supabase real.
DEV_MODE=true

# === Sentry (opcional, recomendado para produção) ===
SENTRY_DSN=
